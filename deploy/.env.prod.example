# Copie para .env.prod e preencha com valores reais antes de subir docker-compose.prod.yml.
# Nao commitar o .env.prod preenchido.

# Dominio real que aponta (DNS A/AAAA) para este servidor. Caddy usa isso para
# emitir automaticamente um certificado TLS via Let's Encrypt.
DOMAIN=exemplo.com.br

# Postgres gerenciado externamente (RDS, Supabase, etc.) - este compose nao sobe
# um Postgres, so backend + redis + proxy.
DB_USERNAME=artisanvault_app
SPRING_DATASOURCE_URL=jdbc:postgresql://host-do-postgres:5432/artisanvault
SPRING_DATASOURCE_PASSWORD=troque-pela-senha-real

JWT_SECRET=troque-por-um-segredo-base64-de-pelo-menos-256-bits
